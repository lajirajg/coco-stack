---
import { SITE } from "~/site";
import NavLink from "~/components/NavLink.astro";

const { title, description } = Astro.props as {
  title: string;
  description?: string;
};

const desc = description ?? SITE.tagline;
const canonicalURL = new URL(Astro.url.pathname, SITE.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={`${SITE.url}/logo.png`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
  </head>
  <body>
    <div class="container fadeIn">
      <div class="shell">
        <header class="nav">
          <a class="brand" href="/" aria-label="Home">
            <img src="/logo.png" alt={SITE.name} class="brandLogo" />
          </a>
          <nav class="navlinks" aria-label="Primary">
            <NavLink href="/services">Services</NavLink>
            <NavLink href="/research">Research</NavLink>
            <NavLink href="/apps">Apps</NavLink>
            <NavLink href="/about">About</NavLink>
            <NavLink href="/contact">Contact</NavLink>
          </nav>

          <details class="mobileMenu">
            <summary class="mobileMenuBtn">Menu</summary>
            <div class="mobileMenuPanel" role="menu">
              <NavLink href="/services">Services</NavLink>
              <NavLink href="/research">Research</NavLink>
              <NavLink href="/apps">Apps</NavLink>
              <NavLink href="/about">About</NavLink>
              <NavLink href="/contact">Contact</NavLink>
            </div>
          </details>
        </header>

        <main>
          <slot />
        </main>

        <footer class="footer">
          <div>
            <span>&copy; {new Date().getFullYear()} {SITE.name}</span>
            <span style="opacity:0.6"> &middot; </span>
            <a href="/services">Work with us</a>
          </div>
          <div style="display:flex; gap:10px; flex-wrap:wrap">
            <a class="pill" href="/apps">Tools</a>
            <a class="pill" href="/research">Research</a>
            <a class="pill" href={SITE.links.linkedin} rel="me" target="_blank">LinkedIn</a>
            <a class="pill" href={SITE.links.medium} rel="me" target="_blank">Medium</a>
            <a class="pill" href={SITE.links.github} rel="me" target="_blank">GitHub</a>
          </div>
        </footer>
      </div>
    </div>
  </body>
</html>
