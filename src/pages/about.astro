---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { SITE } from "~/site";
---

<BaseLayout title={`About - ${SITE.name}`} description="AI advisory grounded in engineering, product thinking, and business outcomes.">
  <section class="hero">
    <div class="kicker">About</div>
    <h1 class="headline">Technology, made relevant.</h1>
    <p class="subhead">
      We work across AI engineering, product strategy, and applied research. Our focus is
      building usable systems, communicating tradeoffs clearly, and keeping delivery grounded
      in business impact.
    </p>
    <div class="ctaRow">
      <a class="btn primary" href={SITE.calLink} target="_blank">Book a call</a>
      <a class="btn" href="/services">Services</a>
    </div>
  </section>

  <section class="grid" aria-label="About details">
    <div class="card span6">
      <h3>What we do</h3>
      <p>
        We help companies navigate the AI landscape with clarity. From assessing
        readiness to shipping prototypes to scaling production systems — we bridge
        the gap between what AI promises and what it actually delivers.
      </p>
      <div class="meta">
        <span class="pill">Strategy</span>
        <span class="pill">Prototyping</span>
        <span class="pill">Advisory</span>
      </div>
    </div>

    <div class="card span6">
      <h3>How we think</h3>
      <p>
        Start with the business problem, not the technology. Validate fast, fail cheap.
        Ship something real before writing a strategy deck. Measure outcomes, not activity.
      </p>
      <div class="meta">
        <span class="pill">Outcome-driven</span>
        <span class="pill">Lean</span>
        <span class="pill">Evidence-based</span>
      </div>
    </div>

    <div class="card span6">
      <h3>Domains</h3>
      <p>
        Deep experience in healthcare and life sciences (including genetics and
        cancer research), financial services, and enterprise SaaS.
        We speak both the technical and business language.
      </p>
      <div class="meta">
        <span class="pill">Healthcare</span>
        <span class="pill">Life Sciences</span>
        <span class="pill">FinTech</span>
        <span class="pill">Enterprise</span>
      </div>
    </div>

    <div class="card span6">
      <h3>Capabilities</h3>
      <p>
        Applied AI, LLM architecture, agentic systems, evaluation and safety-by-design,
        decision support, and automation that reduces friction without creating risk.
      </p>
      <div class="meta">
        <span class="pill">LLMs</span>
        <span class="pill">Agents</span>
        <span class="pill">Evaluation</span>
        <span class="pill">Safety</span>
      </div>
    </div>

    <div class="card span12">
      <h3>Published thinking</h3>
      <p>We share our research openly. Here's some of our recent work:</p>
      <div class="ctaRow" style="margin-top:8px">
        {SITE.medium.map((article) => (
          <a class="btn" href={article.url} target="_blank" rel="noopener">{article.title.split(":")[0]}</a>
        ))}
      </div>
      <div class="meta" style="margin-top:12px">
        <a class="pill" href={SITE.links.medium} target="_blank">All articles on Medium</a>
        <a class="pill" href={SITE.links.linkedin} target="_blank">LinkedIn</a>
      </div>
    </div>
  </section>
</BaseLayout>
