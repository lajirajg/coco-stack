---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { SITE } from "~/site";
import { getCollection } from "astro:content";

const apps = (await getCollection("apps"))
  .filter((p) => !p.data.draft && p.slug !== "hello-apps")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const statusLabel: Record<string, string> = {
  idea: "Idea",
  prototype: "Prototype",
  live: "Live"
};
---

<BaseLayout title={`Apps & Tools - ${SITE.name}`} description="Free AI tools: readiness scorecard, use case prioritizer, and more.">
  <section class="hero">
    <div class="kicker">Apps & Tools</div>
    <h1 class="headline">Free tools, real insights.</h1>
    <p class="subhead">
      Interactive tools to help you evaluate, prioritize, and plan your AI
      initiatives. No signup required.
    </p>
  </section>

  <section class="grid" aria-label="Apps list">
    <!-- AI Readiness Scorecard (standalone page) -->
    <a class="card span6" href="/apps/ai-readiness-scorecard">
      <h3>AI Readiness Scorecard</h3>
      <p>
        10-question assessment across 5 dimensions. Get an instant score,
        per-dimension breakdown, and actionable recommendations.
      </p>
      <div class="meta">
        <span class="pill accent">Live</span>
        <span class="pill">Free</span>
        <span class="pill">3 minutes</span>
      </div>
    </a>

    <!-- AI Use Case Prioritizer (standalone page) -->
    <a class="card span6" href="/apps/use-case-prioritizer">
      <h3>AI Use Case Prioritizer</h3>
      <p>
        Input your business goals, rate feasibility and impact, and get a
        prioritized roadmap with an effort/impact matrix.
      </p>
      <div class="meta">
        <span class="pill accent">Live</span>
        <span class="pill">Free</span>
        <span class="pill">5 minutes</span>
      </div>
    </a>

    <!-- Content collection apps -->
    {apps.map((app) => (
      <a class="card span6" href={app.data.url || `/apps/${app.slug}`}>
        <h3>{app.data.title}</h3>
        <p>{app.data.description}</p>
        <div class="meta">
          <span class="pill">{statusLabel[app.data.status]}</span>
          {app.data.tags.slice(0, 2).map((t) => (
            <span class="pill">{t}</span>
          ))}
        </div>
      </a>
    ))}
  </section>

  <section class="grid">
    <div class="card span12 ctaBanner">
      <h3>Want a custom tool for your team?</h3>
      <p>We build tailored AI tools and prototypes. Let's discuss what would be most valuable for your organization.</p>
      <div class="ctaRow">
        <a class="btn primary" href={SITE.calLink} target="_blank">Book a call</a>
        <a class="btn" href="/services">View services</a>
      </div>
    </div>
  </section>
</BaseLayout>
