---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { SITE } from "~/site";
import { getCollection } from "astro:content";

const apps = (await getCollection("apps"))
  .filter((p) => !p.data.draft && p.slug !== "hello-apps")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const statusLabel: Record<string, string> = {
  idea: "Idea",
  prototype: "Prototype",
  live: "Live"
};
---

<BaseLayout title={`Apps - ${SITE.name}`} description="Free AI tools — no signup, no fluff.">
  <section class="hero">
    <h1 class="headline">Tools that do things.</h1>
    <p class="subhead">
      Built for myself, shared with everyone. No signup required.
    </p>
  </section>

  <section class="grid" aria-label="Apps list">
    <a class="card span6" href="/apps/ai-readiness-scorecard">
      <h3>AI Readiness Scorecard</h3>
      <p>
        10-question assessment across 5 dimensions. Instant score and recommendations.
      </p>
      <div class="meta">
        <span class="pill accent">Live</span>
        <span class="pill">3 min</span>
      </div>
    </a>

    <a class="card span6" href="/apps/use-case-prioritizer">
      <h3>AI Use Case Prioritizer</h3>
      <p>
        Rate feasibility and impact, get a prioritized roadmap with an effort/impact matrix.
      </p>
      <div class="meta">
        <span class="pill accent">Live</span>
        <span class="pill">5 min</span>
      </div>
    </a>

    {apps.map((app) => (
      <a class="card span6" href={app.data.url || `/apps/${app.slug}`}>
        <h3>{app.data.title}</h3>
        <p>{app.data.description}</p>
        <div class="meta">
          <span class="pill">{statusLabel[app.data.status]}</span>
          {app.data.tags.slice(0, 2).map((t) => (
            <span class="pill">{t}</span>
          ))}
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
