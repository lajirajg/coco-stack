---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { SITE } from "~/site";
import { getCollection } from "astro:content";

const apps = (await getCollection("apps"))
  .filter((p) => !p.data.draft && p.slug !== "hello-apps")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const statusLabel: Record<string, string> = {
  idea: "Idea",
  prototype: "Prototype",
  live: "Live"
};
---

<BaseLayout title={`Apps - ${SITE.name}`} description="Free AI tools — no signup, no fluff.">
  <section class="hero">
    <h1 class="headline">Tools that do things.</h1>
    <p class="subhead">
      Built for myself, shared with everyone. No signup required.
    </p>
  </section>

  <!-- Live -->
  <section class="grid" aria-label="Live apps">
    <div class="card span12" style="background:transparent; border:none; padding:0 0 0 2px; min-height:auto;">
      <div class="kicker">Live</div>
    </div>

    <a class="card span6" href="/apps/ai-readiness-scorecard">
      <h3>AI Readiness Scorecard</h3>
      <p>
        10-question assessment across 5 dimensions. Instant score and recommendations.
      </p>
      <div class="meta">
        <span class="pill accent">Live</span>
        <span class="pill">3 min</span>
      </div>
    </a>

    <a class="card span6" href="/apps/use-case-prioritizer">
      <h3>AI Use Case Prioritizer</h3>
      <p>
        Rate feasibility and impact, get a prioritized roadmap with an effort/impact matrix.
      </p>
      <div class="meta">
        <span class="pill accent">Live</span>
        <span class="pill">5 min</span>
      </div>
    </a>

    {apps.map((app) => (
      <a class="card span6" href={app.data.url || `/apps/${app.slug}`}>
        <h3>{app.data.title}</h3>
        <p>{app.data.description}</p>
        <div class="meta">
          <span class="pill">{statusLabel[app.data.status]}</span>
          {app.data.tags.slice(0, 2).map((t) => (
            <span class="pill">{t}</span>
          ))}
        </div>
      </a>
    ))}
  </section>

  <!-- Building Now -->
  <section class="grid" aria-label="In progress">
    <div class="card span12" style="background:transparent; border:none; padding:0 0 0 2px; min-height:auto;">
      <div class="kicker">Building Now</div>
    </div>

    <div class="card span6">
      <h3>NSW Selective Exam Tutor</h3>
      <p>
        AI-powered practice and coaching for the NSW Selective High School entrance exam.
        Adaptive questions, instant feedback, progress tracking.
      </p>
      <div class="meta">
        <span class="pill" style="border-color:rgba(217,119,6,0.3); background:rgba(217,119,6,0.08); color:var(--warn);">In Progress</span>
        <span class="pill">Education</span>
        <span class="pill">AI Tutor</span>
      </div>
      <div class="ctaRow">
        <a class="btn primary" href={`mailto:${SITE.email}?subject=Interested%20in%20NSW%20Selective%20Exam%20Tutor`}>I'm interested</a>
      </div>
    </div>

    <div class="card span6">
      <h3>CocoLedger</h3>
      <p>
        Smart budgeting with AI-assisted categorization and insights.
        Simple, private, and actually useful. Formerly "Personal Budget Tracker."
      </p>
      <div class="meta">
        <span class="pill" style="border-color:rgba(217,119,6,0.3); background:rgba(217,119,6,0.08); color:var(--warn);">In Progress</span>
        <span class="pill">Finance</span>
        <span class="pill">Personal</span>
      </div>
      <div class="ctaRow">
        <a class="btn primary" href={`mailto:${SITE.email}?subject=CocoLedger%20—%20Contact`}>Contact Us</a>
      </div>
    </div>
  </section>

  <!-- Suggest an App -->
  <section class="grid" aria-label="Suggest an app">
    <div class="card span12 ctaBanner">
      <h3>Got an idea for a tool?</h3>
      <p>
        Tell me what you wish existed. If it's interesting enough, I'll build it.
      </p>
      <div class="ctaRow">
        <a class="btn primary" href={`mailto:${SITE.email}?subject=App%20Idea&body=Here's%20what%20I%20wish%20existed%3A%0A%0A`}>Share your idea</a>
      </div>
    </div>
  </section>
</BaseLayout>
