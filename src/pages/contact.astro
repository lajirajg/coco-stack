---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { SITE } from "~/site";
---

<BaseLayout title={`Contact - ${SITE.name}`} description="Book a call or reach out for advisory, prototyping, or collaboration.">
  <section class="hero">
    <div class="kicker">Contact</div>
    <h1 class="headline">Let's build something useful.</h1>
    <p class="subhead">
      Book a free 30-minute discovery call, or send an email with your brief.
      Either way, you'll hear back within 24 hours.
    </p>
    <div class="ctaRow">
      <a class="btn primary" href={SITE.calLink} target="_blank">Book a free call</a>
      <a class="btn" href={`mailto:${SITE.email}?subject=Coco%20Stack%20Inquiry`}>
        Email {SITE.email}
      </a>
      <button class="btn" id="copyEmail" type="button">Copy email</button>
    </div>
  </section>

  <section class="grid" aria-label="Contact details">
    <div class="card span6">
      <h3>What we can help with</h3>
      <ul class="serviceList">
        <li>AI strategy and roadmap development</li>
        <li>Rapid prototyping and proof-of-concepts</li>
        <li>Vendor and tool evaluation</li>
        <li>Team workshops and upskilling</li>
        <li>Architecture review and technical advisory</li>
      </ul>
      <div class="meta">
        <a class="pill" href="/services">View all services</a>
      </div>
    </div>
    <div class="card span6">
      <h3>What to include in your email</h3>
      <ul class="serviceList">
        <li>The business problem you're trying to solve</li>
        <li>What "success" looks like for you</li>
        <li>Any constraints (data, privacy, budget, timeline)</li>
        <li>Whether you have an existing AI initiative or starting fresh</li>
      </ul>
      <div class="meta">
        <span class="pill">Goals</span>
        <span class="pill">Constraints</span>
        <span class="pill">Timeline</span>
      </div>
    </div>

    <div class="card span12">
      <h3>Find us elsewhere</h3>
      <div class="ctaRow">
        <a class="btn" href={SITE.links.linkedin} target="_blank">LinkedIn</a>
        <a class="btn" href={SITE.links.medium} target="_blank">Medium</a>
        <a class="btn" href={SITE.links.github} target="_blank">GitHub</a>
      </div>
    </div>
  </section>

  <script define:vars={{ email: SITE.email }}>
    const btn = document.getElementById("copyEmail");
    btn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(email);
        btn.textContent = "Copied!";
        setTimeout(() => (btn.textContent = "Copy email"), 1200);
      } catch {
        btn.textContent = "Copy failed";
        setTimeout(() => (btn.textContent = "Copy email"), 1200);
      }
    });
  </script>
</BaseLayout>
