---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { SITE } from "~/site";
---

<BaseLayout title={SITE.name} description={SITE.tagline}>
  <section class="hero">
    <h1 class="headline">
      Where AI meets "let's actually build something."
    </h1>
    <p class="subhead">
      Tinkering with AI, shipping tools, and writing about what works (and what doesn't).
      This is where it all lives.
    </p>
  </section>

  <section class="grid" aria-label="What's here">
    <a class="card span4" href="/research">
      <h3>Research</h3>
      <p>
        Deep dives, PoVs, and industry playbooks. My writing plus the best thinking from across the AI landscape.
      </p>
      <div class="meta">
        <span class="pill accent">PoVs</span>
        <span class="pill">Playbooks</span>
      </div>
    </a>

    <a class="card span4" href="/apps">
      <h3>Apps</h3>
      <p>
        Tools I've built and released. Free, useful, no signup walls.
      </p>
      <div class="meta">
        <span class="pill accent">Live</span>
        <span class="pill">Free</span>
      </div>
    </a>

    <a class="card span4" href="/playground">
      <h3>Playground</h3>
      <p>
        Experiments and half-baked ideas. The stuff that's too interesting not to share.
      </p>
      <div class="meta">
        <span class="pill accent">WIP</span>
        <span class="pill">Notes</span>
      </div>
    </a>
  </section>

  <section class="grid" aria-label="Latest writing">
    <div class="card span12">
      <h3>Latest from Medium</h3>
      <div class="ctaRow" style="margin-top:4px">
        {SITE.medium.slice(0, 3).map((article) => (
          <a class="btn" href={article.url} target="_blank" rel="noopener">{article.title.split(":")[0]}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="grid" aria-label="Connect">
    <div class="card span12 ctaBanner">
      <h3>Interesting problem? Let's talk.</h3>
      <p>
        I work with startups and growing companies on AI strategy, architecture, and getting things into production.
      </p>
      <div class="ctaRow">
        <a class="btn primary" href={SITE.calLink} target="_blank">Book a chat</a>
        <a class="btn" href={`mailto:${SITE.email}`}>Email</a>
        <a class="btn" href={SITE.links.linkedin} target="_blank">LinkedIn</a>
        <a class="btn" href={SITE.links.medium} target="_blank">Medium</a>
        <a class="btn" href={SITE.links.x} target="_blank">X</a>
        <a class="btn" href={SITE.links.github} target="_blank">GitHub</a>
      </div>
    </div>
  </section>
</BaseLayout>
