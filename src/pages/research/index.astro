---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { SITE } from "~/site";
import { getCollection } from "astro:content";

const posts = (await getCollection("research"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`Research - ${SITE.name}`} description="Deep dives, frameworks, and points of view on AI strategy and implementation.">
  <section class="hero">
    <div class="kicker">Research & PoVs</div>
    <h1 class="headline">Go deep, stay practical.</h1>
    <p class="subhead">
      Longer reads on AI strategy, architecture, and what actually works.
      Published on Medium and here.
    </p>
  </section>

  <!-- Medium articles -->
  <section class="grid" aria-label="Published articles">
    {SITE.medium.map((article) => (
      <a class="card span6" href={article.url} target="_blank" rel="noopener">
        <div class="meta" style="margin-bottom:8px">
          <span class="pill accent">Medium</span>
          <span class="pill">{article.date}</span>
        </div>
        <h3>{article.title}</h3>
        <div class="meta">
          {article.tags.map((t) => (
            <span class="pill">{t}</span>
          ))}
        </div>
      </a>
    ))}

    {posts.filter(p => p.slug !== "hello-research").map((post) => (
      <a class="card span6" href={`/research/${post.slug}`}>
        <h3>{post.data.title}</h3>
        <p>{post.data.description}</p>
        <div class="meta">
          <span class="pill">
            {post.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "2-digit"
            })}
          </span>
          {post.data.tags.slice(0, 3).map((t) => (
            <span class="pill">{t}</span>
          ))}
        </div>
      </a>
    ))}
  </section>

  <section class="grid">
    <div class="card span12 ctaBanner">
      <h3>Want this thinking applied to your business?</h3>
      <p>Our research directly informs our advisory work. Let's talk about your specific challenges.</p>
      <div class="ctaRow">
        <a class="btn primary" href={SITE.calLink} target="_blank">Book a call</a>
        <a class="btn" href="/services">View services</a>
      </div>
    </div>
  </section>
</BaseLayout>
