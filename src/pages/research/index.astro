---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { SITE } from "~/site";
import { getCollection } from "astro:content";

const posts = (await getCollection("research"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const myArticles = SITE.medium.filter((a) => a.category === "mine");
---

<BaseLayout title={`Research - ${SITE.name}`} description="Deep dives, PoVs, and industry playbooks on AI engineering and strategy.">
  <section class="hero">
    <h1 class="headline">Go deep, stay practical.</h1>
    <p class="subhead">
      Research, PoVs, and the best AI playbooks — all in one place.
    </p>
  </section>

  <!-- My Writing -->
  <section class="grid" aria-label="My writing">
    <div class="card span12" style="background:transparent; border:none; padding:0 0 0 2px; min-height:auto;">
      <div class="kicker">My Writing</div>
    </div>

    {myArticles.map((article) => (
      <a class="card span6" href={article.url} target="_blank" rel="noopener">
        <div class="meta" style="margin-bottom:8px">
          <span class="pill accent">Medium</span>
          <span class="pill">{article.date}</span>
        </div>
        <h3>{article.title}</h3>
        <div class="meta">
          {article.tags.map((t) => (
            <span class="pill">{t}</span>
          ))}
        </div>
      </a>
    ))}

    {posts.filter(p => p.slug !== "hello-research").map((post) => (
      <a class="card span6" href={`/research/${post.slug}`}>
        <h3>{post.data.title}</h3>
        <p>{post.data.description}</p>
        <div class="meta">
          <span class="pill">
            {post.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "2-digit"
            })}
          </span>
          {post.data.tags.slice(0, 3).map((t) => (
            <span class="pill">{t}</span>
          ))}
        </div>
      </a>
    ))}
  </section>

  <!-- Deep Dives -->
  <section class="grid" aria-label="Deep dives">
    <div class="card span12" style="background:transparent; border:none; padding:0 0 0 2px; min-height:auto;">
      <div class="kicker">Deep Dives</div>
    </div>

    <div class="card span12">
      <h3>Coming soon</h3>
      <p>
        Long-form explorations of specific AI topics — architecture patterns, evaluation frameworks,
        production lessons, and things that take more than a blog post to explain.
      </p>
      <div class="meta">
        <span class="pill">Architecture</span>
        <span class="pill">Evaluation</span>
        <span class="pill">Production</span>
      </div>
    </div>
  </section>

  <!-- Industry Playbooks -->
  <section class="grid" aria-label="Industry playbooks">
    <div class="card span12" style="background:transparent; border:none; padding:0 0 0 2px; min-height:auto;">
      <div class="kicker">Industry Playbooks</div>
    </div>

    <div class="card span12">
      <h3>Coming soon</h3>
      <p>
        Curated AI playbooks and frameworks from leading consulting firms and tech companies.
        The best thinking, consolidated.
      </p>
      <div class="meta">
        <span class="pill">McKinsey</span>
        <span class="pill">BCG</span>
        <span class="pill">Google</span>
        <span class="pill">Anthropic</span>
        <span class="pill">+ more</span>
      </div>
    </div>
  </section>
</BaseLayout>
