---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { SITE } from "~/site";
---

<BaseLayout title={`Services - ${SITE.name}`} description="AI advisory services: assessments, strategy sprints, ongoing advisory, and workshops.">
  <section class="hero">
    <div class="kicker">Services</div>
    <h1 class="headline">AI advisory that ships results.</h1>
    <p class="subhead">
      We don't write decks that collect dust. Every engagement has a clear scope,
      a defined outcome, and a timeline you can hold us to.
    </p>
    <div class="ctaRow">
      <a class="btn primary" href={SITE.calLink} target="_blank">Book a free discovery call</a>
      <a class="btn" href="/apps/ai-readiness-scorecard">Check your AI readiness first</a>
    </div>
  </section>

  <section class="grid" aria-label="Service tiers">
    <div class="card span6" id="assessment">
      <div class="serviceLabel">Entry point</div>
      <h3>AI Readiness Assessment</h3>
      <p>
        A focused 2-hour deep dive into your organization's AI maturity: data
        infrastructure, team capabilities, process readiness, and opportunity
        landscape.
      </p>
      <ul class="serviceList">
        <li>90-min structured interview with key stakeholders</li>
        <li>Written assessment report with scores across 5 dimensions</li>
        <li>Prioritized opportunity map with effort/impact ratings</li>
        <li>30-min follow-up to walk through recommendations</li>
      </ul>
      <div class="meta">
        <span class="pill accent">Starting at $1,000</span>
        <span class="pill">1 week delivery</span>
      </div>
    </div>

    <div class="card span6" id="sprint">
      <div class="serviceLabel">Most popular</div>
      <h3>Strategy Sprint</h3>
      <p>
        A two-week engagement that goes from assessment to a working prototype.
        You'll validate your highest-impact AI use case with real results.
      </p>
      <ul class="serviceList">
        <li>Full AI readiness assessment (included)</li>
        <li>Use case prioritization workshop with your team</li>
        <li>Working prototype of the #1 opportunity</li>
        <li>Implementation roadmap and build-vs-buy analysis</li>
        <li>Executive presentation with ROI projections</li>
      </ul>
      <div class="meta">
        <span class="pill accent">Starting at $5,000</span>
        <span class="pill">2 weeks</span>
      </div>
    </div>

    <div class="card span6" id="advisory">
      <div class="serviceLabel">Ongoing</div>
      <h3>Monthly Advisory</h3>
      <p>
        Continuous strategic guidance as you build out your AI capabilities.
        Think of it as a fractional AI advisor on speed dial.
      </p>
      <ul class="serviceList">
        <li>Weekly strategy calls (30 min)</li>
        <li>Architecture and vendor review</li>
        <li>Prototype iterations and technical guidance</li>
        <li>Team upskilling and process optimization</li>
        <li>Priority Slack/email access for ad-hoc questions</li>
      </ul>
      <div class="meta">
        <span class="pill accent">Starting at $3,000/mo</span>
        <span class="pill">Monthly retainer</span>
      </div>
    </div>

    <div class="card span6" id="workshops">
      <div class="serviceLabel">Team enablement</div>
      <h3>AI Workshops</h3>
      <p>
        Hands-on sessions designed for your team's specific context, stack, and
        goals. Not generic AI 101 — practical, applicable, immediately useful.
      </p>
      <ul class="serviceList">
        <li>Prompt engineering for business teams</li>
        <li>Building with LLMs: from APIs to production</li>
        <li>AI product thinking for product managers</li>
        <li>Evaluating AI: metrics, testing, and safety</li>
        <li>Custom topics based on your needs</li>
      </ul>
      <div class="meta">
        <span class="pill accent">Starting at $2,000</span>
        <span class="pill">Half-day / Full-day</span>
      </div>
    </div>
  </section>

  <section class="grid">
    <div class="card span12">
      <h3>How we work</h3>
      <div class="processGrid">
        <div class="processStep">
          <div class="stepNum">1</div>
          <strong>Discovery call</strong>
          <p>Free 30-min conversation. We learn your context, you learn our approach. No pressure.</p>
        </div>
        <div class="processStep">
          <div class="stepNum">2</div>
          <strong>Scope & proposal</strong>
          <p>Clear deliverables, timeline, and pricing. You know exactly what you're getting.</p>
        </div>
        <div class="processStep">
          <div class="stepNum">3</div>
          <strong>Execute</strong>
          <p>We work in tight iterations with frequent check-ins. No surprises, no scope creep.</p>
        </div>
        <div class="processStep">
          <div class="stepNum">4</div>
          <strong>Deliver & measure</strong>
          <p>Tangible outputs tied to your success metrics. We measure what matters to you.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="grid">
    <div class="card span12 ctaBanner">
      <h3>Ready to talk?</h3>
      <p>
        Book a free 30-minute discovery call. We'll discuss your goals, assess
        the fit, and outline next steps — no commitment required.
      </p>
      <div class="ctaRow">
        <a class="btn primary" href={SITE.calLink} target="_blank">Book your free call</a>
        <a class="btn" href={`mailto:${SITE.email}?subject=Coco%20Stack%20Inquiry`}>Or email us</a>
      </div>
    </div>
  </section>
</BaseLayout>
